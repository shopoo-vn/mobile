# Mobile build-time env (NOTHING SECRET — these ship in the client bundle).
# Select which API config block app.config.ts uses: development | staging | production
APP_ENV=development

# On a physical device localhost is the phone itself. Point this at your dev
# machine's LAN IP so the device can reach the backend (e.g. 192.168.1.20).
# Used only when APP_ENV=development.
EXPO_PUBLIC_API_HOST=localhost
